# ===========================================
# NEXT.JS CLIENT ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in your values

# Auth Server URL
# NEXT_PUBLIC_ prefix makes this available in browser
NEXT_PUBLIC_AUTH_SERVER_URL=http://localhost:4000

# MongoDB Connection (for Routes collection)
MONGODB_URI=mongodb://localhost:27017/hiking-routes

# Google Gemini API Key (for route generation)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Weather API Key (OpenWeatherMap)
# Get from: https://openweathermap.org/api
WEATHER_API_KEY=your-openweathermap-api-key

# JWT Secret (must match auth server)
# Used by middleware to verify tokens
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production


# Unsplash API Key (OPTIONAL - real photos for route/country images)
# Get from: https://unsplash.com/developers (create app, use Access Key)
# If not set: uses Pollinations (AI-generated), then Picsum if load fails
UNSPLASH_ACCESS_KEY=your-unsplash-access-key-optional
